{
  "name": "intro-nodejs",
  "description": "A simple CLI note-taking app - a course project for \"Introduction to Node.js v3\"",
  "version": "1.0.0-alpha.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "note": "src/index.js"
  },
  "homepage": "https://github.com/flow145/intro-nodejs#readme",
  "bugs": "https://github.com/flow145/intro-nodejs/issues",
  "repository": "git@github.com:flow145/intro-nodejs.git",
  "scripts": {
    "dev": "node --watch src/index.js",
    "format": "biome format --reporter=summary",
    "format:fix": "npm run format -- --write",
    "check": "biome check --reporter=summary",
    "check:fix": "npm run check -- --write",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "jest": "^30.3.0",
    "lefthook": "^2.1.4"
  },
  "dependencies": {
    "open": "^11.0.0",
    "yargs": "^18.0.0"
  }
}
